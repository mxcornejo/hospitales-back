{
  "info": {
    "name": "Hospital - Sumativa 3 Kafka",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key":"baseUrl","value":"http://54.210.62.242:8080"},
    {"key":"kafkaUiUrl","value":"http://32.197.126.175:8085"},
    {"key":"token","value":""}
  ],
  "item": [
    {
      "name": "1. Login",
      "request": {
        "method": "POST",
        "header": [{"key":"Content-Type","value":"application/json"}],
        "body": {"mode":"raw","raw":"{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"},
        "url": "{{baseUrl}}/api/auth/login"
      },
      "event": [{"listen":"test","script":{"exec":["const body = pm.response.json();", "pm.collectionVariables.set('token', body.token);"]}}]
    },
    {
      "name": "2. Listar pacientes",
      "request": {"method":"GET","header":[{"key":"Authorization","value":"Bearer {{token}}"}],"url":"{{baseUrl}}/api/pacientes"}
    },
    {
      "name": "3. Listar alertas persistidas desde Kafka",
      "request": {"method":"GET","header":[{"key":"Authorization","value":"Bearer {{token}}"}],"url":"{{baseUrl}}/api/alertas"}
    },
    {
      "name": "4. Alertas por paciente",
      "request": {"method":"GET","header":[{"key":"Authorization","value":"Bearer {{token}}"}],"url":"{{baseUrl}}/api/alertas/paciente/1"}
    }
  ]
}
